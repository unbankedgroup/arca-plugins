{
  "name": "arca",
  "version": "1.0.0-alpha",
  "description": "Arca — AI ops platform for SMBs. Skills, hooks, MCP servers, and agent profiles for running multi-agent operations.",
  "author": "Unbanked",
  "repository": "https://github.com/unbankedgroup/arca-plugin",

  "skills": [
    { "name": "arca-ops", "path": "skills/arca-ops/SKILL.md" },
    { "name": "arca-worker", "path": "skills/arca-worker/SKILL.md" },
    { "name": "usage", "path": "skills/usage/SKILL.md" },
    { "name": "watch-agent", "path": "skills/watch-agent/SKILL.md" }
  ],

  "hooks": {
    "SessionStart": [
      { "command": "$ARCA_HOME/ops/migrations/arca-plugin-v1/plugin/hooks/session-start/on-start.sh", "events": ["startup", "resume"] },
      { "command": "$ARCA_HOME/ops/migrations/arca-plugin-v1/plugin/hooks/session-start/reconnect-plugin.sh" },
      { "command": "cat $ARCA_HOME/ops/migrations/arca-plugin-v1/plugin/hooks/session-start/session-start-template.md" }
    ],
    "UserPromptSubmit": [
      { "command": "$ARCA_HOME/ops/migrations/arca-plugin-v1/plugin/hooks/user-prompt-submit/dispatcher.py" },
      { "command": "$ARCA_HOME/ops/migrations/arca-plugin-v1/plugin/hooks/user-prompt-submit/check-mcp-heartbeat.sh" }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_telegram_telegram__reply",
        "command": "$ARCA_HOME/ops/migrations/arca-plugin-v1/plugin/hooks/pre-tool-use/reply-validator.py"
      }
    ]
  },

  "mcpServers": {
    "ops-board": {
      "type": "stdio",
      "command": "bun",
      "args": ["$ARCA_HOME/ops/migrations/arca-plugin-v1/plugin/mcp-servers/ops-board/channel.ts"],
      "env": {
        "OPS_BOARD_URL": "https://ops.runarca.xyz",
        "OPS_AGENT_NAME": "${ARCA_AGENT_NAME}",
        "OPS_WEBHOOK_PORT": "${ARCA_WEBHOOK_PORT}",
        "OPS_WORKSPACE": "${ARCA_WORKSPACE}"
      }
    }
  },

  "commands": {
    "usage": { "description": "Check API budget usage", "skill": "usage" },
    "watch-agent": { "description": "Monitor an agent's tmux pane", "skill": "watch-agent" },
    "arca-ops": { "description": "Interact with the Arca Ops Board", "skill": "arca-ops" },
    "arca-worker": { "description": "Pick up and execute ops board tasks", "skill": "arca-worker" }
  },

  "requiredEnvVars": [
    "ARCA_HOME",
    "ARCA_WORKSPACE",
    "ARCA_AGENT_NAME",
    "ARCA_WEBHOOK_PORT",
    "TELEGRAM_STATE_DIR",
    "ARCA_LICENSE_KEY"
  ],

  "optionalEnvVars": [
    "ARCA_OPS_URL",
    "ARCA_VAULT_ROOT",
    "ARCA_MODEL"
  ],

  "agents": [
    { "name": "cognis", "path": "agents/cognis/", "role": "Strategy & Orchestration" },
    { "name": "mara", "path": "agents/mara/", "role": "X Growth Operator" },
    { "name": "_template", "path": "agents/_template/", "role": "Template for new agents" }
  ]
}