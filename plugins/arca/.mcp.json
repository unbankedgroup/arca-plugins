{
  "mcpServers": {
    "ops-board": {
      "command": "bun",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/ops-board/channel.ts"],
      "env": {
        "OPS_BOARD_URL": "https://ops.runarca.xyz",
        "OPS_AGENT_NAME": "${ARCA_AGENT_NAME}",
        "OPS_POLL_INTERVAL": "5000",
        "OPS_WEBHOOK_PORT": "${ARCA_WEBHOOK_PORT}",
        "OPS_WORKSPACE": "${ARCA_WORKSPACE}"
      }
    }
  }
}