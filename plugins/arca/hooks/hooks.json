{
  "description": "Arca ops platform hooks — session boot, prompt dispatch, and Telegram reply validation",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start/on-start.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start/reconnect-plugin.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit/dispatcher.py" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit/check-mcp-heartbeat.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_telegram_telegram__reply",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use/reply-validator.py" }
        ]
      }
    ]
  }
}